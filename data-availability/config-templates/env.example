# Environment Configuration Template
# Based on: "Modernization of Enterprise Payment Infrastructure: A Case Study on LLM-Assisted Migration of Legacy Distributed Systems"
# Research Paper reference: Environment management (Appendix A)
#
# SECURITY NOTE: This is a template with all secrets removed.
# Replace [PLACEHOLDER] values with actual credentials in your environment.

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
APP_NAME=PaymentPortal
APP_URL=https://pay.example.com
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================================================
# SESSION MANAGEMENT
# ============================================================================
# Research Paper reference: Session timeout handling (Section 2)
SESSION_DRIVER=redis
SESSION_TIMEOUT_MINUTES=30
SESSION_WARNING_MINUTES=25
SESSION_ENCRYPTION_KEY=[REPLACE_WITH_RANDOM_32_BYTE_KEY]
SESSION_COOKIE_NAME=pay_session

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Research Paper reference: Database optimization (Appendix A)
DB_CONNECTION=mysql
DB_HOST=[REPLACE_WITH_DB_HOST]
DB_PORT=3306
DB_USER=[REPLACE_WITH_DB_USER]
DB_PASSWORD=[REPLACE_WITH_DB_PASSWORD]
DB_DATABASE=payment_portal

# Read replica configuration for balance queries
DB_READ_REPLICA_HOST=[REPLACE_WITH_REPLICA_HOST]
DB_READ_REPLICA_PORT=3306

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=[REPLACE_WITH_REDIS_HOST]
REDIS_PORT=6379
REDIS_PASSWORD=[REPLACE_WITH_REDIS_PASSWORD]
REDIS_KEY_PREFIX=pay:

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Research Paper reference: Enterprise SSO integration (Appendix A)
OIDC_CLIENT_ID=[REPLACE_WITH_OIDC_CLIENT_ID]
OIDC_CLIENT_SECRET=[REPLACE_WITH_OIDC_CLIENT_SECRET]
OIDC_REDIRECT_URI=https://pay.example.com/auth/callback
OIDC_ISSUER_URL=https://auth.example.com
OIDC_SCOPE=openid profile email

# ============================================================================
# PAYMENT PROCESSOR CONFIGURATION
# ============================================================================
# Research Paper reference: Dual payment processing strategy (Section 2.1)

# Chase Paymentech Configuration (Normal customers)
CHASE_API_KEY=[REPLACE_WITH_CHASE_API_KEY]
CHASE_MERCHANT_ID=[REPLACE_WITH_MERCHANT_ID]
CHASE_IFRAME_URL=https://paymentech.chase.com/payment-iframe
CHASE_WEBHOOK_SECRET=[REPLACE_WITH_WEBHOOK_SECRET]

# PCIPal Configuration (Support agents)
PCIPAL_API_KEY=[REPLACE_WITH_PCIPAL_API_KEY]
PCIPAL_BEARER_TOKEN=[REPLACE_WITH_BEARER_TOKEN]
PCIPAL_WEBSOCKET_URL=wss://api.pcipal.com/websocket/payment-session
PCIPAL_IFRAME_URL=https://api.pcipal.com/iframe

# ============================================================================
# EXTERNAL SYSTEM INTEGRATION
# ============================================================================
# Research Paper reference: URL handling and redirects (Appendix A)

# Development Environment
EXTERNAL_REDIRECT_ERROR_DEV=https://external-dev.example.com/error
EXTERNAL_REDIRECT_TIMEOUT_DEV=https://external-dev.example.com/timeout
EXTERNAL_REDIRECT_SUCCESS_DEV=https://external-dev.example.com/success

# Production Environment
EXTERNAL_REDIRECT_ERROR=https://external.example.com/error
EXTERNAL_REDIRECT_TIMEOUT=https://external.example.com/timeout
EXTERNAL_REDIRECT_SUCCESS=https://external.example.com/success

# ============================================================================
# CURRENCY CONVERSION
# ============================================================================
# Research Paper reference: Multi-currency support (Appendix A)
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_RATE_API_KEY=[REPLACE_WITH_API_KEY]
SUPPORTED_CURRENCIES=USD,GBP,EUR,CAD,AUD

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================
# Research Paper reference: Security implementation (Section 2.4)
CSRF_ENABLED=true
CORS_ENABLED=true
CORS_ORIGIN=https://pay.example.com
HELMET_ENABLED=true

# Content Security Policy
CSP_SCRIPT_SRC=self,unsafe-inline,https://api.pcipal.com,https://paymentech.chase.com
CSP_FRAME_SRC=self,https://api.pcipal.com,https://paymentech.chase.com
CSP_CONNECT_SRC=self,wss://api.pcipal.com,https://api.exchangerate.host

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Research Paper reference: Monitoring and observability (Appendix A)
GCP_PROJECT_ID=[REPLACE_WITH_PROJECT_ID]
GCP_TRACE_ENABLED=true
GCP_ERROR_REPORTING_ENABLED=true
LOG_STRUCTURED=true

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
# Research Paper reference: Performance optimization (Section 3.3)
PAYMENT_TIMEOUT_MS=300000
PAYMENT_RETRY_ATTEMPTS=3
DB_POOL_MIN=2
DB_POOL_MAX=10
REDIS_POOL_MIN=5
REDIS_POOL_MAX=20

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_CUSTOMER_BALANCE_CHECK=true
FEATURE_IMPERSONATION=true
FEATURE_MULTI_CURRENCY=true
FEATURE_ASYNC_BALANCE_QUERY=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# NOTES FOR IMPLEMENTATION
# ============================================================================
# 1. Generate SESSION_ENCRYPTION_KEY: openssl rand -hex 32
# 2. Store all [REPLACE_WITH_*] values in Google Secret Manager
# 3. Never commit this file with actual credentials to version control
# 4. Use environment-specific .env files (.env.dev, .env.prod)
# 5. Validate all required variables on application startup
